# CRMworlds Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String (from MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/crmworlds

# Port to run the server on
PORT=3000

# Admin key for accessing the email list at /emails?adminKey=YOUR_KEY
ADMIN_KEY=your-secret-admin-key-here
